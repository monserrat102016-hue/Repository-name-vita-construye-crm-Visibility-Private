# =============================================
# VITA CONSTRUYE CRM — Variables de entorno
# =============================================
# Copia este archivo como .env y llena los valores.
# NUNCA subas .env a GitHub.

# === BASE DE DATOS ===
# Desarrollo local (SQLite): deja este valor tal cual
DATABASE_URL="file:./dev.db"

# Producción en Vercel + Neon Postgres:
# 1. Ve a neon.tech y crea una cuenta gratuita
# 2. Crea un proyecto "vita-construye"
# 3. Copia la cadena de conexión y pégala aquí
# DATABASE_URL="postgresql://usuario:contraseña@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# === AUTENTICACIÓN ===
# Genera un valor aleatorio seguro (mínimo 32 caracteres)
# Puedes generarlo con: openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-un-valor-secreto-largo-y-aleatorio"

# === INTELIGENCIA ARTIFICIAL (opcional) ===
# Si tienes API Key de Anthropic, el asistente AI estará activo.
# Si no tienes o no pones nada, el CRM funciona igual con plantillas locales.
# Obtén tu llave en: console.anthropic.com
ANTHROPIC_API_KEY=""

# === URL DE LA APP ===
# En local: http://localhost:3000
# En Vercel: https://tu-proyecto.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
